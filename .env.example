# Required for live OpenAI generation and embeddings.
OPENAI_API_KEY=your_openai_api_key_here

# Optional alias for the same OpenAI API key.
# If both are set, OPENAI_API_KEY takes precedence.
CCA_OPENAI_API_KEY=

# Optional generation model override.
CCA_OPENAI_MODEL=gpt-5-mini

# Optional embedding model override for retrieval and KB indexing.
CCA_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional default generation provider.
CCA_DEFAULT_GENERATION_PROVIDER=openai

# Optional UI/runtime defaults.
CCA_DEFAULT_DOMAIN=three_js
CCA_DEFAULT_MODE=generate

# Optional local paths.
CCA_CHROMA_PERSIST_DIR=data/chroma
CCA_ARTIFACT_DIR=data/artifacts
CCA_EVAL_DATA_PATH=data/eval/live_sessions.jsonl

# Optional logging.
CCA_LOG_LEVEL=INFO
