# Required for live OpenAI generation and embeddings.
OPENAI_API_KEY=your_openai_api_key_here

# Optional alias for the same OpenAI API key.
# If both are set, OPENAI_API_KEY takes precedence.
CCA_OPENAI_API_KEY=

# Optional generation model override.
CCA_OPENAI_MODEL=gpt-5-mini

# Optional cap for live generation output during local demos.
CCA_OPENAI_MAX_OUTPUT_TOKENS=4000

# Bounded timeout for one live generation request. SDK retries stay disabled so
# any retry remains an explicit reviewed product action.
CCA_OPENAI_TIMEOUT_SECONDS=90

# Optional embedding model override for retrieval and KB indexing.
CCA_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional default generation provider.
CCA_DEFAULT_GENERATION_PROVIDER=openai

# Optional UI/runtime defaults.
CCA_ENVIRONMENT=local
CCA_DEFAULT_DOMAIN=three_js
CCA_DEFAULT_MODE=generate

# Optional local paths.
CCA_CHROMA_PERSIST_DIR=data/chroma
CCA_ARTIFACT_DIR=data/artifacts
CCA_WORKSPACE_SESSION_DB_PATH=data/workspace_sessions.sqlite3
CCA_EVAL_DATA_PATH=data/eval/live_sessions.jsonl
CCA_EVAL_RAGAS_RESULTS_PATH=data/eval/ragas_results.jsonl

# Optional local RAGAs evaluator controls.
CCA_EVAL_RAGAS_MODEL=gpt-4o-mini
CCA_EVAL_RAGAS_TIMEOUT_SECONDS=180
CCA_EVAL_RAGAS_MAX_RETRIES=2
CCA_EVAL_RAGAS_MAX_WORKERS=2

# Optional logging.
CCA_LOG_LEVEL=INFO
CCA_LOG_FORMAT=text

# LangSmith tracing (optional).
# LANGSMITH_* is the primary Creative Coding Assistant config.
# LANGCHAIN_* aliases are also supported for LangChain/LangGraph compatibility.
# Tracing is disabled by default unless a local environment opts in.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=creative-coding-assistant
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGCHAIN_PROJECT=creative-coding-assistant
# LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
