{
  "name": "@creative-coding-assistant/nextjs-client",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src e2e",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:ci": "npm run typecheck && npm run test && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/workstation-smoke.spec.js --project=chromium",
    "quality:dashboard": "python ../../scripts/v7_quality_gates.py dashboard"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.20.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.20",
    "jsdom": "29.1.1",
    "typescript": "5.7.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "postcss": "8.5.18"
  }
}
